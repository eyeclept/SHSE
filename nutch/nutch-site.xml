<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>

  <!--
    Generated by SHSE. This file is mounted into the Nutch container at
    /root/nutch_source/runtime/local/conf/nutch-site.xml.

    TLS NOTE: http.tls.certificates.check defaults to false in Nutch 1.23,
    so self-signed certificates are already accepted without changes to this
    file. The property is listed here explicitly so the setting is visible
    and auditable. Remove or set to true to enforce certificate validation.

    Long-term recommendation: mount your homelab CA cert into the Nutch
    container's JVM trust store (cacerts) rather than relying on this flag.
  -->

  <property>
    <name>http.timeout</name>
    <value>10000</value>
    <description>HTTP fetch timeout in milliseconds.</description>
  </property>

  <!--
    TLS certificate check. Set to false to allow self-signed / expired certs.
    Applied globally to all crawls on this server instance.
    Per-crawl overrides are applied dynamically via PUT /config/{id}/http.tls.certificates.check
    by flask_app/services/nutch.trigger_crawl() when tls_verify=False on a target.
  -->
  <property>
    <name>http.tls.certificates.check</name>
    <value>false</value>
    <description>
      Whether to check TLS/SSL server certificates for validity.
      false = accept self-signed and expired certificates (dev/homelab use).
      true  = reject invalid certificates.
    </description>
  </property>

</configuration>
