# SHSE — Non-secret configuration template
# Copy this file to config.ini and fill in your deployment values.
# config.ini is gitignored — never commit it.
# Secrets (passwords, keys, tokens) belong in .env — never here.

[mariadb]
host = YOUR_SERVICES_HOST
port = 3306
db   = shse
user = shse_user

[opensearch]
host = YOUR_SERVICES_HOST
port = 9200
user = admin

[redis]
host = YOUR_SERVICES_HOST
port = 6379

[nutch]
host = YOUR_SERVICES_HOST
port = 8081
; default_depth — how many link-hops to follow from the seed URL when a target has no explicit depth set
; max_depth     — upper bound enforced by the UI and crawl task (prevents runaway crawls)
default_depth = 2
max_depth     = 16
; max_urls — BFS URL cap per crawl run. Raise for large sites (e.g. 50000 for full Wikipedia).
max_urls      = 500

[llm]
; api_base — Ollama or compatible endpoint. Leave blank to disable LLM features.
; Each model below must be pulled/available in the configured backend, or the
; corresponding feature (summary / rewrite / translate) silently no-ops. These
; defaults match the in-code fallbacks (flask_app/config.py).
api_base        = http://YOUR_LLM_HOST:11434/v1
embed_model     = nomic-embed-text
gen_model       = granite4.1:8b
rewrite_model   = granite4.1:3b
translate_model = aya-expanse:8b
query_rewrite   = false
; Set to true to enable CPU embedding fallback (requires sentence-transformers)
cpu_fallback    = false

[stardict]
; Path to StarDict dictionary files inside the container
dict_path = /app/dicts

[tls]
# Verify the internal OpenSearch TLS certificate. Takes effect only when ca_cert
# below points to a CA bundle that can validate the OpenSearch server cert. With
# no ca_cert the internal services use self-signed certs that cannot be verified,
# so verification is skipped and a warning is logged. Set both to enable real
# verification against a trusted CA.
internal_verify = true
ca_cert =

[sso]
enabled      = false
provider_url =
client_id    =
admin_group  = admin
local_auth   = true

[webauthn]
; rp_id and origin must match the domain users access SHSE from
rp_id   = YOUR_DOMAIN_OR_IP
rp_name = SHSE
origin  = https://YOUR_DOMAIN_OR_IP

[smtp]
; Leave host blank to disable outbound email
host = YOUR_SMTP_HOST
port = 1025
user =
from = noreply@shse.local
tls  = false

[app]
; Public URL of the SHSE instance (used in password reset emails)
url = https://YOUR_DOMAIN_OR_IP

[mcp]
host     = 0.0.0.0
port     = 8765
result_k = 10

[ratelimit]
; Login attempts allowed per IP per minute.
; Production: 10 per minute  (brute-force protection)
; Development/test: 60 per minute  (prevents test suite from hitting the limit)
login = 10 per minute
