# SHSE — Environment Variables Configuration
# Copy this file to .env and adjust for your deployment
# All services are assumed to be network-reachable at their configured hosts:ports

# ============================================================================
# FLASK APPLICATION
# ============================================================================
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=supersecretkey123
# ============================================================================
# MARIADB DATABASE
# ============================================================================
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_USER=shse_user
MARIADB_PASSWORD=CHANGE-ME
MARIADB_DATABASE=shse
MYSQL_ROOT_PASSWORD=CHANGE-ME

# ============================================================================
# ELASTICSEARCH
# ============================================================================
ES_HOST=elasticsearch
ES_PORT=9200
ES_SCHEME=http
# JVM memory for Elasticsearch (production: -Xms4g -Xmx4g or higher)
ES_JAVA_OPTS=-Xms1g -Xmx1g

# ============================================================================
# REDIS (Celery Broker)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# Full Redis URL used by Celery (auto-constructed if not set)
# REDIS_URL=redis://redis:6379/0

# ============================================================================
# APACHE NUTCH
# ============================================================================
NUTCH_HOST=nutch
NUTCH_PORT=8080
# JVM memory for Nutch crawling (production: -Xmx4g or higher)
JAVA_OPTS=-Xmx2g

# ============================================================================
# OLLAMA (Local LLM)
# ============================================================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
# Model names — adjust based on your installed models
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_GENERATIVE_MODEL=llama3

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Local password auth (default: enabled)
AUTH_LOCAL_ENABLED=true

# SSO/OIDC (optional, default: disabled)
SSO_ENABLED=false
SSO_PROVIDER_URL=https://authentik.homelab.lan
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# ============================================================================
# TLS / HTTPS
# ============================================================================
# WARNING: Set to false ONLY in trusted internal networks (development/homelab)
# For production, use proper certificates and set to true
INTERNAL_TLS_VERIFY=false

# ============================================================================
# MULTI-VM DEPLOYMENT EXAMPLE
# ============================================================================
# If running services on separate VMs, override here:
#
# MARIADB_HOST=172.16.1.10
# ES_HOST=172.16.1.20
# REDIS_HOST=172.16.1.30
# NUTCH_HOST=172.16.1.40
# OLLAMA_HOST=172.16.1.50
