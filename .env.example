# SHSE — Secrets Template
# Copy to .env and fill in real values. Never commit .env.
# Non-secret config (hosts, ports, models, etc.) lives in config.ini.

# --- Flask ---
SECRET_KEY=change-me-to-a-long-random-string

# --- MariaDB ---
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# --- OpenSearch ---
OPENSEARCH_INITIAL_ADMIN_PASSWORD=

# --- Redis ---
# Leave blank to run Redis without authentication (development only).
# Set a strong password for any network-accessible deployment (SEC-008).
REDIS_PASSWORD=

# --- SSO (optional — leave blank to use local password auth) ---
SSO_CLIENT_SECRET=

# --- SMTP (optional — leave blank to disable email password recovery) ---
SMTP_PASSWORD=

# --- Answer cards (optional) ---
# The weather and date/time answer cards read these from the environment
# (flask_app/services/weather_cards.py, datetime_cards.py). All are optional;
# leave blank to disable the corresponding source. The card stays off until a
# source is fully configured.
#
# Weather source priority: Home Assistant -> InfluxDB -> Open-Meteo -> NWS.
#   Home Assistant (REST API):
# HA_URL=
# HA_TOKEN=
# HA_WEATHER_ENTITY=weather.home
#   InfluxDB (Flux query):
# INFLUXDB_URL=
# INFLUXDB_TOKEN=
# INFLUXDB_ORG=
# INFLUXDB_BUCKET=
# INFLUXDB_MEASUREMENT=weather
#   Open-Meteo / NWS (no API key; just coordinates):
# LAT=
# LON=
#
# Date/time card — NTP server for an authoritative clock (falls back to system clock):
# NTP_SERVER=
