# SHSE — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env.

# --- Flask ---
SECRET_KEY=change-me-to-a-long-random-string

# --- MariaDB ---
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DB=shse
MARIADB_USER=shse_user
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Nutch ---
NUTCH_HOST=localhost
NUTCH_PORT=8080

# --- LLM API (Ollama / LiteLLM) ---
LLM_API_BASE=http://localhost:11434/v1
LLM_EMBED_MODEL=nomic-embed-text
LLM_GEN_MODEL=granite4.1:8b
LLM_REWRITE_MODEL=granite4.1:3b
# Set to true to rewrite conversational queries before hitting OpenSearch
QUERY_REWRITE_ENABLED=false

# --- TLS ---
INTERNAL_TLS_VERIFY=true

# --- MCP Server (optional — start with: docker compose --profile mcp up mcp_server) ---
MCP_HOST=0.0.0.0
MCP_PORT=8765
MCP_RESULT_K=10

# --- SSO (leave blank / false to use local password auth) ---
SSO_ENABLED=false
SSO_PROVIDER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
AUTH_LOCAL_ENABLED=true
