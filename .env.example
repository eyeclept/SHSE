# SHSE — Environment Variable Template
# Copy to .env and fill in real values. Never commit .env.

# --- Flask ---
SECRET_KEY=change-me-to-a-long-random-string

# --- MariaDB ---
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DB=shse
MARIADB_USER=shse_user
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Nutch ---
NUTCH_HOST=localhost
NUTCH_PORT=8080

# --- Ollama ---
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# --- TLS ---
INTERNAL_TLS_VERIFY=true

# --- SSO (leave blank / false to use local password auth) ---
SSO_ENABLED=false
SSO_PROVIDER_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
AUTH_LOCAL_ENABLED=true
